# =============================================================================
# FinApp Backend -- Environment Variables
# Copia este archivo a .env y ajusta los valores para tu entorno local.
# NUNCA commitees el archivo .env real.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development          # development | production

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=finapp
DB_PASSWORD=finapp
DB_NAME=finapp_dev
# Usada por golang-migrate y pgx directamente
DATABASE_URL=postgres://finapp:finapp@localhost:5432/finapp_dev?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string-min32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h   # 7 dias
BCRYPT_COST=10            # desarrollo: 10, produccion: 12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Lista de origenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000
